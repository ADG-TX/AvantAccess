rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // GOTA HVAC unit data
    // All 152 units — open read/write for now.
    // Restrict to authenticated users once Firebase Auth is added:
    //   allow read, write: if request.auth != null;
    match /units/{unitId} {
      allow read, write: if true;
    }

  }
}
