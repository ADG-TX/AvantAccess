rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── GOTA HVAC unit data ────────────────────────────────────────
    match /units/{unitId} {
      allow read, write: if request.auth != null;
    }

    // ── Clubhouse, site photos, and other property-level data ──────
    match /properties/{propId} {
      allow read, write: if request.auth != null;
    }

    // ── Maintenance plan intake (brochure sign-ups) ───────────────
    // Public write so unauthenticated garage owners can submit the form.
    // Read is restricted to authenticated users (the dashboard).
    match /intake_requests/{requestId} {
      allow read:  if request.auth != null;
      allow write: if true;
    }

  }
}
