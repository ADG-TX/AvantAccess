rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── GOTA HVAC unit data ────────────────────────────────────────
    match /units/{unitId} {
      allow read, write: if request.auth != null;
    }

    // ── Clubhouse, site photos, and other property-level data ──────
    match /properties/{propId} {
      allow read, write: if request.auth != null;
    }

  }
}
