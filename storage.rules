rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── GOTA HVAC unit photos ──────────────────────────────────────
    match /units/{unitId}/photos/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── GOTA HVAC voice recordings ────────────────────────────────
    match /units/{unitId}/recordings/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 300 * 1024 * 1024;
    }

    // ── Clubhouse photos ──────────────────────────────────────────
    match /clubhouse/photos/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Jobsite / site archive photos ─────────────────────────────
    match /jobsite/photos/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Per-unit GC buildout plans ────────────────────────────────
    match /units/{unitId}/designs/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // ── AvantAccess customer design uploads ───────────────────────
    match /designs/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

  }
}
