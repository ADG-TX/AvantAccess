rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── GOTA HVAC unit photos ──────────────────────────────────────
    // Allows any client to read and write photos under units/*/photos/
    // Restrict to authenticated users once Firebase Auth is added:
    //   allow read, write: if request.auth != null;
    match /units/{unitId}/photos/{filename} {
      allow read:  if true;
      allow write: if request.resource.size < 15 * 1024 * 1024   // max 15 MB
                   && request.resource.contentType.matches('image/.*'); // images only
    }

    // ── AvantAccess customer design uploads ───────────────────────
    match /designs/{filename} {
      allow read:  if true;
      allow write: if request.resource.size < 25 * 1024 * 1024;
    }

  }
}
