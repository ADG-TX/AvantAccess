rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── GOTA HVAC unit photos ──────────────────────────────────────
    // Private to signed-in staff only.
    match /units/{unitId}/photos/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024   // max 15 MB
                   && request.resource.contentType.matches('image/.*'); // images only
    }

    // ── GOTA HVAC voice recordings ────────────────────────────────
    // Private business conversations — signed-in staff only.
    match /units/{unitId}/recordings/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 300 * 1024 * 1024;
    }

    // ── AvantAccess customer design uploads ───────────────────────
    match /designs/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

  }
}
